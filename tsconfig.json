{
  "compilerOptions": {
    "target": "es6",
    "module": "es6",
    "outDir": "dist",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "dslquery": ["./src/index.js"],
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*"
  ]
}